param([Parameter(Mandatory=$true)][string]$RepoRoot)

$ErrorActionPreference = "Stop"
Set-StrictMode -Version Latest
`$InputDir = $null

function Die([string]$m){ throw $m }

function Write-Utf8NoBomLf([string]$Path,[string]$Content){
  $parent = Split-Path -Parent $Path
  if($parent -and -not (Test-Path -LiteralPath $parent -PathType Container)){
    New-Item -ItemType Directory -Force -Path $parent | Out-Null
  }
  $lf = $Content.Replace("`r`n","`n").Replace("`r","`n")
  if(-not $lf.EndsWith("`n")){ $lf += "`n" }
  $enc = New-Object System.Text.UTF8Encoding($false)
  [System.IO.File]::WriteAllText($Path,$lf,$enc)
}

function Parse-Gate([string]$Path){
  if(-not (Test-Path -LiteralPath $Path -PathType Leaf)){ Die ("PARSEGATE_MISSING: " + $Path) }
  $null = [ScriptBlock]::Create((Get-Content -Raw -LiteralPath $Path -Encoding UTF8))
}

if(-not (Test-Path -LiteralPath $RepoRoot -PathType Container)){ Die ("MISSING_REPO: " + $RepoRoot) }
$ScriptsDir = Join-Path $RepoRoot "scripts"
$DocsDir    = Join-Path $RepoRoot "docs"
New-Item -ItemType Directory -Force -Path $ScriptsDir | Out-Null
New-Item -ItemType Directory -Force -Path $DocsDir    | Out-Null
$CaptureTree = Join-Path $ScriptsDir "triad_capture_tree_v1.ps1"
$SelfTestTx  = Join-Path $ScriptsDir "_selftest_triad_tree_transcript_v1.ps1"
$DocPath     = Join-Path $DocsDir   "TRIAD_TREE_TRANSCRIPT_SPEC_v1.md"

# Backup only what we touch
$ts = (Get-Date).ToUniversalTime().ToString("yyyyMMdd_HHmmss")
$BackupDir = Join-Path $ScriptsDir ("_backup_tree_dualtx_" + $ts)
New-Item -ItemType Directory -Force -Path $BackupDir | Out-Null
foreach($p in @($CaptureTree,$SelfTestTx,$DocPath)){
  if(Test-Path -LiteralPath $p){
    Copy-Item -LiteralPath $p -Destination (Join-Path $BackupDir ((Split-Path -Leaf $p) + ".pre_patch")) -Force
  }
}

$capLines = New-Object System.Collections.Generic.List[string]
$null = $capLines.Add("param(")
$null = $capLines.Add("  [Parameter(Mandatory=$true)][string]$RepoRoot,")
$null = $capLines.Add("  [Parameter(Mandatory=$true)][string]$InputDir,")
$null = $capLines.Add("  [Parameter(Mandatory=$true)][string]$OutDir,")
$null = $capLines.Add("  [int]$BlockSize = 1048576")
$null = $capLines.Add(")")
$null = $capLines.Add("")
$null = $capLines.Add("$ErrorActionPreference = `"Stop`"")
$null = $capLines.Add("Set-StrictMode -Version Latest")
$null = $capLines.Add("")
$null = $capLines.Add("function Die([string]$m){ throw $m }")
$null = $capLines.Add("")
$null = $capLines.Add("function WriteUtf8NoBomLf([string]$Path,[string]$Content){")
$null = $capLines.Add("  $parent = Split-Path -Parent $Path")
$null = $capLines.Add("  if($parent -and -not (Test-Path -LiteralPath $parent -PathType Container)){")
$null = $capLines.Add("    New-Item -ItemType Directory -Force -Path $parent | Out-Null")
$null = $capLines.Add("  }")
$null = $capLines.Add("  $lf = $Content.Replace(`"``r``n`",`"``n`").Replace(`"``r`",`"``n`")")
$null = $capLines.Add("  if(-not $lf.EndsWith(`"``n`")){ $lf += `"``n`" }")
$null = $capLines.Add("  $enc = New-Object System.Text.UTF8Encoding($false)")
$null = $capLines.Add("  [System.IO.File]::WriteAllText($Path,$lf,$enc)")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("function Sha256HexBytes([byte[]]$Bytes){")
$null = $capLines.Add("  if($null -eq $Bytes){ Die `"SHA256_BYTES_NULL`" }")
$null = $capLines.Add("  $sha = [System.Security.Cryptography.SHA256]::Create()")
$null = $capLines.Add("  try { $h = $sha.ComputeHash([byte[]]$Bytes); ($h | ForEach-Object { $_.ToString(`"x2`") }) -join `"`" } finally { $sha.Dispose() }")
$null = $capLines.Add("}")
$null = $capLines.Add("function Sha256HexText([string]$Text){ Sha256HexBytes ([System.Text.Encoding]::UTF8.GetBytes([string]$Text)) }")
$null = $capLines.Add("function Sha256HexFile([string]$Path){ if(-not (Test-Path -LiteralPath $Path -PathType Leaf)){ Die (`"MISSING_FILE: `" + $Path) }; (Get-FileHash -Algorithm SHA256 -LiteralPath $Path).Hash.ToLowerInvariant() }")
$null = $capLines.Add("")
$null = $capLines.Add("function HexToBytes([string]$Hex){")
$null = $capLines.Add("  if([string]::IsNullOrWhiteSpace($Hex)){ Die `"HEX_EMPTY`" }")
$null = $capLines.Add("  if(($Hex.Length % 2) -ne 0){ Die (`"HEX_ODD_LEN: `" + $Hex.Length) }")
$null = $capLines.Add("  $len = [int]($Hex.Length / 2)")
$null = $capLines.Add("  $b = New-Object byte[] $len")
$null = $capLines.Add("  for($i=0; $i -lt $len; $i++){ $b[$i] = [Convert]::ToByte($Hex.Substring($i*2,2),16) }")
$null = $capLines.Add("  $b")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("function MerkleRootHex([string[]]$HexHashesInOrder){")
$null = $capLines.Add("  $arr = @(@($HexHashesInOrder))")
$null = $capLines.Add("  if($arr.Count -lt 1){ Die `"MERKLE_EMPTY`" }")
$null = $capLines.Add("  $level = New-Object System.Collections.Generic.List[byte[]]")
$null = $capLines.Add("  foreach($hx in $arr){ [void]$level.Add((HexToBytes $hx)) }")
$null = $capLines.Add("  while($level.Count -gt 1){")
$null = $capLines.Add("    $next = New-Object System.Collections.Generic.List[byte[]]")
$null = $capLines.Add("    for($i=0; $i -lt $level.Count; $i += 2){")
$null = $capLines.Add("      $a = $level[$i]; $b = $null")
$null = $capLines.Add("      if(($i+1) -lt $level.Count){ $b = $level[$i+1] } else { $b = $level[$i] }")
$null = $capLines.Add("      $cat = New-Object byte[] ($a.Length + $b.Length)")
$null = $capLines.Add("      [Array]::Copy($a,0,$cat,0,$a.Length)")
$null = $capLines.Add("      [Array]::Copy($b,0,$cat,$a.Length,$b.Length)")
$null = $capLines.Add("      $sha = [System.Security.Cryptography.SHA256]::Create()")
$null = $capLines.Add("      try { $h = $sha.ComputeHash($cat); [void]$next.Add($h) } finally { $sha.Dispose() }")
$null = $capLines.Add("    }")
$null = $capLines.Add("    $level = $next")
$null = $capLines.Add("  }")
$null = $capLines.Add("  ($level[0] | ForEach-Object { $_.ToString(`"x2`") }) -join `"`"")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("function NormalizeRelPath([string]$BaseDir,[string]$FullPath){")
$null = $capLines.Add("  $base = [IO.Path]::GetFullPath($BaseDir).TrimEnd(`"\`")")
$null = $capLines.Add("  $full = [IO.Path]::GetFullPath($FullPath)")
$null = $capLines.Add("  if(-not $full.StartsWith($base,[StringComparison]::OrdinalIgnoreCase)){ Die (`"PATH_OUTSIDE_BASE: base=`" + $base + `" full=`" + $full) }")
$null = $capLines.Add("  $rel = $full.Substring($base.Length).TrimStart(`"\`",`"/`")")
$null = $capLines.Add("  ($rel -replace `"\\`",`"/`")")
$null = $capLines.Add("}")
$null = $capLines.Add("function EntryHashV1([string]$Type,[string]$Rel,[int64]$Len,[string]$Sha){ Sha256HexText (`"triad.tree.entry.v1|{0}|{1}|{2}|{3}`" -f $Type,$Rel,$Len,$Sha) }")
$null = $capLines.Add("")
$null = $capLines.Add("# ---- inputs ----")
$null = $capLines.Add("if(-not (Test-Path -LiteralPath $RepoRoot -PathType Container)){ Die (`"MISSING_REPO: `" + $RepoRoot) }")
$null = $capLines.Add("if(-not (Test-Path -LiteralPath $InputDir -PathType Container)){ Die (`"MISSING_INPUT_DIR: `" + $InputDir) }")
$null = $capLines.Add("if($BlockSize -lt 4096){ Die (`"BLOCKSIZE_TOO_SMALL: `" + $BlockSize) }")
$null = $capLines.Add("")
$null = $capLines.Add("New-Item -ItemType Directory -Force -Path $OutDir | Out-Null")
$null = $capLines.Add("$BlocksDir = Join-Path $OutDir `"blocks`"")
$null = $capLines.Add("New-Item -ItemType Directory -Force -Path $BlocksDir | Out-Null")
$null = $capLines.Add("")
$null = $capLines.Add("# ---- Load NeverLost identity (hard-reset then dot-source) ----")
$null = $capLines.Add("$ScriptsDir = Join-Path $RepoRoot `"scripts`"")
$null = $capLines.Add("$LibPath    = Join-Path $ScriptsDir `"_lib_neverlost_v1.ps1`"")
$null = $capLines.Add("if(-not (Test-Path -LiteralPath $LibPath -PathType Leaf)){ Die (`"LIB_MISSING: `" + $LibPath) }")
$null = $capLines.Add("Remove-Variable -Name NL_LIB_LOADED -Scope Global -ErrorAction SilentlyContinue")
$null = $capLines.Add("Remove-Item -Path Function:\NL-* -ErrorAction SilentlyContinue")
$null = $capLines.Add(". $LibPath")
$null = $capLines.Add("if(-not (Get-Command NL-GetDefaultPrincipalAndKey -ErrorAction SilentlyContinue)){ Die (`"NL_LIB_LOAD_FAILED: missing NL-GetDefaultPrincipalAndKey :: `" + $LibPath) }")
$null = $capLines.Add("$ident = NL-GetDefaultPrincipalAndKey $RepoRoot")
$null = $capLines.Add("")
$null = $capLines.Add("# --------------------------------------------")
$null = $capLines.Add("# Dual Transcript v1")
$null = $capLines.Add("# - ENGINE transcript: deterministic across runs (NO wall-clock time in hash basis)")
$null = $capLines.Add("# - WITNESS transcript: run-unique (includes ts_utc in hash basis)")
$null = $capLines.Add("# Back-compat: transcript.ndjson + snapshot.transcript_root remain WITNESS.")
$null = $capLines.Add("# --------------------------------------------")
$null = $capLines.Add("$WitnessPathLegacy     = Join-Path $OutDir `"transcript.ndjson`"")
$null = $capLines.Add("$WitnessRootLegacyPath = Join-Path $OutDir `"snapshot.transcript_root`"")
$null = $capLines.Add("$WitnessPath           = Join-Path $OutDir `"witness.transcript.ndjson`"")
$null = $capLines.Add("$WitnessRootPath       = Join-Path $OutDir `"snapshot.witness_transcript_root`"")
$null = $capLines.Add("$EnginePath            = Join-Path $OutDir `"engine.transcript.ndjson`"")
$null = $capLines.Add("$EngineRootPath        = Join-Path $OutDir `"snapshot.engine_transcript_root`"")
$null = $capLines.Add("")
$null = $capLines.Add("$WLines  = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("$WHashes = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("$WPrev   = (`"0`" * 64)")
$null = $capLines.Add("$WSeq    = 0")
$null = $capLines.Add("$ELines  = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("$EHashes = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("$EPrev   = (`"0`" * 64)")
$null = $capLines.Add("$ESeq    = 0")
$null = $capLines.Add("")
$null = $capLines.Add("function Add-WitnessTranscript([string]$Event,[object]$DataObj){")
$null = $capLines.Add("  $script:WSeq = [int]$script:WSeq + 1")
$null = $capLines.Add("  $ts = (Get-Date).ToUniversalTime().ToString(`"o`")")
$null = $capLines.Add("  $dataJson = `"`"")
$null = $capLines.Add("  if($null -ne $DataObj){ $dataJson = ($DataObj | ConvertTo-Json -Depth 16 -Compress) }")
$null = $capLines.Add("  $basis = (`"triad.transcript_line.v1|{0}|{1}|{2}|{3}|{4}`" -f $script:WSeq,$ts,$Event,$script:WPrev,$dataJson)")
$null = $capLines.Add("  $h = Sha256HexText $basis")
$null = $capLines.Add("  $o = [ordered]@{ seq=[int]$script:WSeq; ts_utc=$ts; event=$Event; prev_sha256=$script:WPrev; data_json=$dataJson; sha256=$h }")
$null = $capLines.Add("  $line = ([pscustomobject]$o | ConvertTo-Json -Depth 8 -Compress)")
$null = $capLines.Add("  [void]$script:WLines.Add($line); [void]$script:WHashes.Add($h); $script:WPrev = $h")
$null = $capLines.Add("}")
$null = $capLines.Add("function Add-EngineTranscript([string]$Event,[object]$DataObj){")
$null = $capLines.Add("  $script:ESeq = [int]$script:ESeq + 1")
$null = $capLines.Add("  $dataJson = `"`"")
$null = $capLines.Add("  if($null -ne $DataObj){ $dataJson = ($DataObj | ConvertTo-Json -Depth 16 -Compress) }")
$null = $capLines.Add("  $basis = (`"triad.engine_transcript_line.v1|{0}|{1}|{2}|{3}`" -f $script:ESeq,$Event,$script:EPrev,$dataJson)")
$null = $capLines.Add("  $h = Sha256HexText $basis")
$null = $capLines.Add("  $o = [ordered]@{ seq=[int]$script:ESeq; event=$Event; prev_sha256=$script:EPrev; data_json=$dataJson; sha256=$h }")
$null = $capLines.Add("  $line = ([pscustomobject]$o | ConvertTo-Json -Depth 8 -Compress)")
$null = $capLines.Add("  [void]$script:ELines.Add($line); [void]$script:EHashes.Add($h); $script:EPrev = $h")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("$startData = [ordered]@{ input_dir_name=(Split-Path -Leaf (Resolve-Path -LiteralPath $InputDir).Path); block_size=[int]$BlockSize; principal=[string]$ident.principal; key_id=[string]$ident.key_id }")
$null = $capLines.Add("Add-EngineTranscript  `"capture.start`" $startData")
$null = $capLines.Add("Add-WitnessTranscript `"capture.start`" $startData")
$null = $capLines.Add("")
$null = $capLines.Add("# ---- enumerate tree deterministically ----")
$null = $capLines.Add("$dirs  = Get-ChildItem -LiteralPath $InputDir -Recurse -Force -Directory -ErrorAction Stop")
$null = $capLines.Add("$files = Get-ChildItem -LiteralPath $InputDir -Recurse -Force -File      -ErrorAction Stop")
$null = $capLines.Add("$dirRel = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("foreach($d in @($dirs)){ $r = NormalizeRelPath $InputDir $d.FullName; if(-not [string]::IsNullOrWhiteSpace($r)){ [void]$dirRel.Add($r) } }")
$null = $capLines.Add("$dirRelSorted = @($dirRel.ToArray() | Sort-Object)")
$null = $capLines.Add("$fileRel = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("foreach($f in @($files)){ $r = NormalizeRelPath $InputDir $f.FullName; if(-not [string]::IsNullOrWhiteSpace($r)){ [void]$fileRel.Add($r) } }")
$null = $capLines.Add("$fileRelSorted = @($fileRel.ToArray() | Sort-Object)")
$null = $capLines.Add("")
$null = $capLines.Add("$entries      = New-Object System.Collections.Generic.List[object]")
$null = $capLines.Add("$entryHashes  = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("$uniqueBlocks = New-Object System.Collections.Generic.HashSet[string]([StringComparer]::OrdinalIgnoreCase)")
$null = $capLines.Add("$totalBytes = [int64]0; $dirCount = 0; $fileCount = 0")
$null = $capLines.Add("")
$null = $capLines.Add("# DIR entries first")
$null = $capLines.Add("foreach($rp in $dirRelSorted){")
$null = $capLines.Add("  $eh = EntryHashV1 `"dir`" $rp 0 `"`"")
$null = $capLines.Add("  [void]$entryHashes.Add($eh)")
$null = $capLines.Add("  $o = [ordered]@{ type=`"dir`"; path=$rp; entry_hash=$eh }")
$null = $capLines.Add("  [void]$entries.Add([pscustomobject]$o)")
$null = $capLines.Add("  $tx = [ordered]@{ path=$rp; entry_hash=$eh }")
$null = $capLines.Add("  Add-EngineTranscript  `"capture.entry.dir`" $tx")
$null = $capLines.Add("  Add-WitnessTranscript `"capture.entry.dir`" $tx")
$null = $capLines.Add("  $dirCount++")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("# FILE entries")
$null = $capLines.Add("foreach($rp in $fileRelSorted){")
$null = $capLines.Add("  $full = Join-Path $InputDir ($rp -replace `"/`",`"\`")")
$null = $capLines.Add("  if(-not (Test-Path -LiteralPath $full -PathType Leaf)){ Die (`"ENUM_FILE_MISSING: `" + $full) }")
$null = $capLines.Add("  $fi = Get-Item -LiteralPath $full")
$null = $capLines.Add("  $len = [int64]$fi.Length; $totalBytes += $len; $fileCount++")
$null = $capLines.Add("  $fileSha = Sha256HexFile $full")
$null = $capLines.Add("  $blockHashes = New-Object System.Collections.Generic.List[string]")
$null = $capLines.Add("  $blockSizes  = New-Object System.Collections.Generic.List[int]")
$null = $capLines.Add("  $offsets     = New-Object System.Collections.Generic.List[int64]")
$null = $capLines.Add("  $fs = [System.IO.File]::Open($full,[System.IO.FileMode]::Open,[System.IO.FileAccess]::Read,[System.IO.FileShare]::Read)")
$null = $capLines.Add("  try {")
$null = $capLines.Add("    $buf = New-Object byte[] $BlockSize")
$null = $capLines.Add("    $off = [int64]0")
$null = $capLines.Add("    while($true){")
$null = $capLines.Add("      $read = $fs.Read($buf,0,$buf.Length)")
$null = $capLines.Add("      if($read -le 0){ break }")
$null = $capLines.Add("      $slice = $buf")
$null = $capLines.Add("      if($read -ne $buf.Length){ $slice = New-Object byte[] $read; [Array]::Copy($buf,0,$slice,0,$read) }")
$null = $capLines.Add("      $bh = Sha256HexBytes $slice")
$null = $capLines.Add("      $blkPath = Join-Path $BlocksDir ($bh + `".blk`")")
$null = $capLines.Add("      if(-not (Test-Path -LiteralPath $blkPath -PathType Leaf)){ [IO.File]::WriteAllBytes($blkPath,$slice) }")
$null = $capLines.Add("      [void]$blockHashes.Add($bh); [void]$blockSizes.Add([int]$read); [void]$offsets.Add([int64]$off)")
$null = $capLines.Add("      $off += $read; [void]$uniqueBlocks.Add($bh)")
$null = $capLines.Add("    }")
$null = $capLines.Add("    if($off -ne $len){ Die (`"FILE_LEN_MISMATCH: `" + $rp + `" read=`" + $off + `" expected=`" + $len) }")
$null = $capLines.Add("  } finally { $fs.Dispose() }")
$null = $capLines.Add("  $fileBlockRoot = `"`"")
$null = $capLines.Add("  if($blockHashes.Count -gt 0){ $fileBlockRoot = MerkleRootHex ($blockHashes.ToArray()) }")
$null = $capLines.Add("  $blkArr = New-Object System.Collections.Generic.List[object]")
$null = $capLines.Add("  for($i=0; $i -lt $blockHashes.Count; $i++){")
$null = $capLines.Add("    $bo = [ordered]@{ index=$i; offset=[int64]$offsets[$i]; size=[int]$blockSizes[$i]; sha256=[string]$blockHashes[$i]; path=(`"blocks/{0}.blk`" -f [string]$blockHashes[$i]) }")
$null = $capLines.Add("    [void]$blkArr.Add([pscustomobject]$bo)")
$null = $capLines.Add("  }")
$null = $capLines.Add("  $eh = EntryHashV1 `"file`" $rp $len $fileSha")
$null = $capLines.Add("  [void]$entryHashes.Add($eh)")
$null = $capLines.Add("  $eo = [ordered]@{ type=`"file`"; path=$rp; length=$len; sha256=$fileSha; entry_hash=$eh; roots=[ordered]@{ block_root=$fileBlockRoot }; blocks=$blkArr.ToArray() }")
$null = $capLines.Add("  [void]$entries.Add([pscustomobject]$eo)")
$null = $capLines.Add("  $tx = [ordered]@{ path=$rp; length=[int64]$len; sha256=$fileSha; entry_hash=$eh; block_root=$fileBlockRoot; blocks=[int]$blockHashes.Count }")
$null = $capLines.Add("  Add-EngineTranscript  `"capture.entry.file`" $tx")
$null = $capLines.Add("  Add-WitnessTranscript `"capture.entry.file`" $tx")
$null = $capLines.Add("}")
$null = $capLines.Add("")
$null = $capLines.Add("if($entries.Count -lt 1){ Die `"CAPTURE_TREE_EMPTY`" }")
$null = $capLines.Add("$semanticRoot = MerkleRootHex ($entryHashes.ToArray())")
$null = $capLines.Add("$blockRoot = `"`"")
$null = $capLines.Add("$uniq = @(@($uniqueBlocks.ToArray()) | ForEach-Object { $_.ToLowerInvariant() })")
$null = $capLines.Add("$uniqSorted = @($uniq | Sort-Object)")
$null = $capLines.Add("if($uniqSorted.Count -gt 0){ $blockRoot = MerkleRootHex $uniqSorted } else { $blockRoot = `"`" }")
$null = $capLines.Add("")
$null = $capLines.Add("$endData = [ordered]@{ files=[int]$fileCount; dirs=[int]$dirCount; total_bytes=[int64]$totalBytes; semantic_root=$semanticRoot; block_root=$blockRoot }")
$null = $capLines.Add("Add-EngineTranscript  `"capture.end`" $endData")
$null = $capLines.Add("Add-WitnessTranscript `"capture.end`" $endData")
$null = $capLines.Add("")
$null = $capLines.Add("$engineTranscriptRoot  = MerkleRootHex ($EHashes.ToArray())")
$null = $capLines.Add("$witnessTranscriptRoot = MerkleRootHex ($WHashes.ToArray())")
$null = $capLines.Add("")
$null = $capLines.Add("WriteUtf8NoBomLf $EnginePath     (($ELines.ToArray() -join `"``n`") + `"``n`")")
$null = $capLines.Add("WriteUtf8NoBomLf $EngineRootPath ($engineTranscriptRoot + `"``n`")")
$null = $capLines.Add("")
$null = $capLines.Add("WriteUtf8NoBomLf $WitnessPath     (($WLines.ToArray() -join `"``n`") + `"``n`")")
$null = $capLines.Add("WriteUtf8NoBomLf $WitnessRootPath ($witnessTranscriptRoot + `"``n`")")
$null = $capLines.Add("")
$null = $capLines.Add("WriteUtf8NoBomLf $WitnessPathLegacy     (($WLines.ToArray() -join `"``n`") + `"``n`")")
$null = $capLines.Add("WriteUtf8NoBomLf $WitnessRootLegacyPath ($witnessTranscriptRoot + `"``n`")")
$null = $capLines.Add("")
$null = $capLines.Add("$sidStr = (`"triad.snapshot_tree.v1|{0}|{1}|{2}|{3}|{4}|{5}`" -f $BlockSize,$fileCount,$dirCount,$totalBytes,$semanticRoot,$blockRoot)")
$null = $capLines.Add("$sid = Sha256HexText $sidStr")
$null = $capLines.Add("")
$null = $capLines.Add("$manifestPath = Join-Path $OutDir `"snapshot.tree.manifest.json`"")
$null = $capLines.Add("$man = [ordered]@{")
$null = $capLines.Add("  schema      = `"triad.snapshot_tree.v1`"")
$null = $capLines.Add("  snapshot_id = $sid")
$null = $capLines.Add("  created_utc = (Get-Date).ToUniversalTime().ToString(`"o`")")
$null = $capLines.Add("  identity    = [ordered]@{ principal=[string]$ident.principal; key_id=[string]$ident.key_id; pubkey=[string]$ident.pubkey }")
$null = $capLines.Add("  source      = [ordered]@{ input_dir_name=(Split-Path -Leaf (Resolve-Path -LiteralPath $InputDir).Path); files=[int]$fileCount; dirs=[int]$dirCount; total_bytes=[int64]$totalBytes }")
$null = $capLines.Add("  chunking    = [ordered]@{ block_size = [int]$BlockSize }")
$null = $capLines.Add("  roots       = [ordered]@{")
$null = $capLines.Add("    semantic_root            = $semanticRoot")
$null = $capLines.Add("    block_root               = $blockRoot")
$null = $capLines.Add("    transcript_root          = $witnessTranscriptRoot  # legacy alias")
$null = $capLines.Add("    witness_transcript_root  = $witnessTranscriptRoot")
$null = $capLines.Add("    engine_transcript_root   = $engineTranscriptRoot")
$null = $capLines.Add("  }")
$null = $capLines.Add("  transcript         = [ordered]@{ path=`"transcript.ndjson`";         root_path=`"snapshot.transcript_root`" }")
$null = $capLines.Add("  witness_transcript = [ordered]@{ path=`"witness.transcript.ndjson`"; root_path=`"snapshot.witness_transcript_root`" }")
$null = $capLines.Add("  engine_transcript  = [ordered]@{ path=`"engine.transcript.ndjson`";  root_path=`"snapshot.engine_transcript_root`" }")
$null = $capLines.Add("  entries = $entries.ToArray()")
$null = $capLines.Add("}")
$null = $capLines.Add("WriteUtf8NoBomLf $manifestPath (($man | ConvertTo-Json -Depth 20) + `"``n`")")
$null = $capLines.Add("$manifestSha = Sha256HexFile $manifestPath")
$null = $capLines.Add("")
$null = $capLines.Add("Write-Host `"OK: TRIAD CAPTURE TREE v1 (DUAL TRANSCRIPT v1)`" -ForegroundColor Green")
$null = $capLines.Add("Write-Host (`"snapshot_dir:           {0}`" -f $OutDir) -ForegroundColor Cyan")
$null = $capLines.Add("Write-Host (`"snapshot_id:            {0}`" -f $sid) -ForegroundColor Cyan")
$null = $capLines.Add("Write-Host (`"manifest_sha256:        {0}`" -f $manifestSha) -ForegroundColor DarkGray")
$null = $capLines.Add("Write-Host (`"semantic_root:          {0}`" -f $semanticRoot) -ForegroundColor DarkGray")
$null = $capLines.Add("Write-Host (`"block_root:             {0}`" -f $blockRoot) -ForegroundColor DarkGray")
$null = $capLines.Add("Write-Host (`"engine_transcript_root: {0}`" -f $engineTranscriptRoot) -ForegroundColor DarkGray")
$null = $capLines.Add("Write-Host (`"witness_transcript_root:{0}`" -f $witnessTranscriptRoot) -ForegroundColor DarkGray")
$null = $capLines.Add("Write-Host (`"files/dirs/bytes:       {0}/{1}/{2}`" -f $fileCount,$dirCount,$totalBytes) -ForegroundColor DarkGray")
$null = $capLines.Add("")
$null = $capLines.Add("$sid")
$cap = (($capLines.ToArray()) -join "`n") + "`n"
Write-Utf8NoBomLf $CaptureTree $cap
Parse-Gate $CaptureTree

$stLines = New-Object System.Collections.Generic.List[string]
$null = $stLines.Add("param([Parameter(Mandatory=$true)][string]$RepoRoot)")
$null = $stLines.Add("$ErrorActionPreference = `"Stop`"")
$null = $stLines.Add("Set-StrictMode -Version Latest")
$null = $stLines.Add("function Die([string]$m){ throw $m }")
$null = $stLines.Add("function ParseGate([string]$Path){ if(-not (Test-Path -LiteralPath $Path -PathType Leaf)){ Die (`"PARSEGATE_MISSING: `" + $Path) }; $null = [ScriptBlock]::Create((Get-Content -Raw -LiteralPath $Path -Encoding UTF8)) }")
$null = $stLines.Add("function Sha256HexBytes([byte[]]$Bytes){ if($null -eq $Bytes){ Die `"SHA256_BYTES_NULL`" }; $sha=[System.Security.Cryptography.SHA256]::Create(); try{ $h=$sha.ComputeHash([byte[]]$Bytes); ($h|ForEach-Object{$_.ToString(`"x2`")}) -join `"`" } finally { $sha.Dispose() } }")
$null = $stLines.Add("function Sha256HexText([string]$Text){ Sha256HexBytes ([System.Text.Encoding]::UTF8.GetBytes([string]$Text)) }")
$null = $stLines.Add("function HexToBytes([string]$Hex){ if([string]::IsNullOrWhiteSpace($Hex)){ Die `"HEX_EMPTY`" }; if(($Hex.Length%2)-ne 0){ Die (`"HEX_ODD_LEN: `"+$Hex.Length) }; $len=[int]($Hex.Length/2); $b=New-Object byte[] $len; for($i=0;$i -lt $len;$i++){ $b[$i]=[Convert]::ToByte($Hex.Substring($i*2,2),16) }; $b }")
$null = $stLines.Add("function MerkleRootHex([string[]]$HexHashesInOrder){ $arr=@(@($HexHashesInOrder)); if($arr.Count -lt 1){ Die `"MERKLE_EMPTY`" }; $level=New-Object System.Collections.Generic.List[byte[]]; foreach($hx in $arr){ [void]$level.Add((HexToBytes $hx)) }; while($level.Count -gt 1){ $next=New-Object System.Collections.Generic.List[byte[]]; for($i=0;$i -lt $level.Count;$i+=2){ $a=$level[$i]; if(($i+1)-lt $level.Count){ $b=$level[$i+1] } else { $b=$level[$i] }; $cat=New-Object byte[] ($a.Length+$b.Length); [Array]::Copy($a,0,$cat,0,$a.Length); [Array]::Copy($b,0,$cat,$a.Length,$b.Length); $sha=[System.Security.Cryptography.SHA256]::Create(); try{ $h=$sha.ComputeHash($cat); [void]$next.Add($h) } finally { $sha.Dispose() } }; $level=$next }; ($level[0]|ForEach-Object{$_.ToString(`"x2`")}) -join `"`" }")
$null = $stLines.Add("function ReadJson([string]$Path){ if(-not (Test-Path -LiteralPath $Path -PathType Leaf)){ Die (`"MISSING_FILE: `"+$Path) }; $raw=(Get-Content -Raw -LiteralPath $Path -Encoding UTF8).Replace(`"``r``n`",`"``n`").Replace(`"``r`",`"``n`"); try{ $raw | ConvertFrom-Json } catch { Die (`"JSON_PARSE_FAIL: `"+$Path+`" :: `"+$_.Exception.Message) } }")
$null = $stLines.Add("")
$null = $stLines.Add("function Validate-WitnessTranscript([string]$TxPath,[string]$RootPath,[string]$ExpectedRoot){")
$null = $stLines.Add("  if(-not (Test-Path -LiteralPath $TxPath -PathType Leaf)){ Die (`"MISSING_WITNESS_TX: `"+$TxPath) }")
$null = $stLines.Add("  if(-not (Test-Path -LiteralPath $RootPath -PathType Leaf)){ Die (`"MISSING_WITNESS_ROOTFILE: `"+$RootPath) }")
$null = $stLines.Add("  $rootFile=(Get-Content -Raw -LiteralPath $RootPath -Encoding UTF8).Replace(`"``r``n`",`"``n`").Replace(`"``r`",`"``n`").Trim()")
$null = $stLines.Add("  if($rootFile -ne $ExpectedRoot){ Die (`"WITNESS_ROOT_FILE_MISMATCH: file=`"+$rootFile+`" expected=`"+$ExpectedRoot) }")
$null = $stLines.Add("  $lines=@(@((Get-Content -LiteralPath $TxPath -Encoding UTF8) | ForEach-Object{ $_.Trim() } | Where-Object{ $_ -ne `"`" }))")
$null = $stLines.Add("  if($lines.Count -lt 1){ Die `"WITNESS_TRANSCRIPT_EMPTY`" }")
$null = $stLines.Add("  $prev=(`"0`"*64)")
$null = $stLines.Add("  $hashes=New-Object System.Collections.Generic.List[string]")
$null = $stLines.Add("  foreach($ln in $lines){")
$null = $stLines.Add("    try{ $o=$ln | ConvertFrom-Json } catch { Die (`"WITNESS_JSON_PARSE_FAIL: `"+$_.Exception.Message) }")
$null = $stLines.Add("    $seq=[int]$o.seq; $ts=[string]$o.ts_utc; $ev=[string]$o.event; $pv=[string]$o.prev_sha256; $dj=[string]$o.data_json; $sh=[string]$o.sha256")
$null = $stLines.Add("    if($pv -ne $prev){ Die (`"WITNESS_PREV_MISMATCH: seq=`"+$seq) }")
$null = $stLines.Add("    $basis=(`"triad.transcript_line.v1|{0}|{1}|{2}|{3}|{4}`" -f $seq,$ts,$ev,$pv,$dj)")
$null = $stLines.Add("    $reh=Sha256HexText $basis")
$null = $stLines.Add("    if($reh -ne $sh){ Die (`"WITNESS_LINE_HASH_MISMATCH: seq=`"+$seq) }")
$null = $stLines.Add("    [void]$hashes.Add($sh); $prev=$sh")
$null = $stLines.Add("  }")
$null = $stLines.Add("  $root=MerkleRootHex ($hashes.ToArray())")
$null = $stLines.Add("  if($root -ne $ExpectedRoot){ Die (`"WITNESS_ROOT_MISMATCH: expected=`"+$ExpectedRoot+`" got=`"+$root) }")
$null = $stLines.Add("}")
$null = $stLines.Add("")
$null = $stLines.Add("function Validate-EngineTranscript([string]$TxPath,[string]$RootPath,[string]$ExpectedRoot){")
$null = $stLines.Add("  if(-not (Test-Path -LiteralPath $TxPath -PathType Leaf)){ Die (`"MISSING_ENGINE_TX: `"+$TxPath) }")
$null = $stLines.Add("  if(-not (Test-Path -LiteralPath $RootPath -PathType Leaf)){ Die (`"MISSING_ENGINE_ROOTFILE: `"+$RootPath) }")
$null = $stLines.Add("  $rootFile=(Get-Content -Raw -LiteralPath $RootPath -Encoding UTF8).Replace(`"``r``n`",`"``n`").Replace(`"``r`",`"``n`").Trim()")
$null = $stLines.Add("  if($rootFile -ne $ExpectedRoot){ Die (`"ENGINE_ROOT_FILE_MISMATCH: file=`"+$rootFile+`" expected=`"+$ExpectedRoot) }")
$null = $stLines.Add("  $lines=@(@((Get-Content -LiteralPath $TxPath -Encoding UTF8) | ForEach-Object{ $_.Trim() } | Where-Object{ $_ -ne `"`" }))")
$null = $stLines.Add("  if($lines.Count -lt 1){ Die `"ENGINE_TRANSCRIPT_EMPTY`" }")
$null = $stLines.Add("  $prev=(`"0`"*64)")
$null = $stLines.Add("  $hashes=New-Object System.Collections.Generic.List[string]")
$null = $stLines.Add("  foreach($ln in $lines){")
$null = $stLines.Add("    try{ $o=$ln | ConvertFrom-Json } catch { Die (`"ENGINE_JSON_PARSE_FAIL: `"+$_.Exception.Message) }")
$null = $stLines.Add("    $seq=[int]$o.seq; $ev=[string]$o.event; $pv=[string]$o.prev_sha256; $dj=[string]$o.data_json; $sh=[string]$o.sha256")
$null = $stLines.Add("    if($pv -ne $prev){ Die (`"ENGINE_PREV_MISMATCH: seq=`"+$seq) }")
$null = $stLines.Add("    $basis=(`"triad.engine_transcript_line.v1|{0}|{1}|{2}|{3}`" -f $seq,$ev,$pv,$dj)")
$null = $stLines.Add("    $reh=Sha256HexText $basis")
$null = $stLines.Add("    if($reh -ne $sh){ Die (`"ENGINE_LINE_HASH_MISMATCH: seq=`"+$seq) }")
$null = $stLines.Add("    [void]$hashes.Add($sh); $prev=$sh")
$null = $stLines.Add("  }")
$null = $stLines.Add("  $root=MerkleRootHex ($hashes.ToArray())")
$null = $stLines.Add("  if($root -ne $ExpectedRoot){ Die (`"ENGINE_ROOT_MISMATCH: expected=`"+$ExpectedRoot+`" got=`"+$root) }")
$null = $stLines.Add("}")
$null = $stLines.Add("")
$null = $stLines.Add("if(-not (Test-Path -LiteralPath $RepoRoot -PathType Container)){ Die (`"MISSING_REPO: `"+$RepoRoot) }")
$null = $stLines.Add("$ScriptsDir = Join-Path $RepoRoot `"scripts`"")
$null = $stLines.Add("$Capture = Join-Path $ScriptsDir `"triad_capture_tree_v1.ps1`"")
$null = $stLines.Add("ParseGate $Capture")
$null = $stLines.Add("$WorkRoot = Join-Path $ScriptsDir `"_work`"")
$null = $stLines.Add("New-Item -ItemType Directory -Force -Path $WorkRoot | Out-Null")
$null = $stLines.Add("")
$null = $stLines.Add("function New-RunDir([string]$Tag){")
$null = $stLines.Add("  $RunId=(Get-Date).ToUniversalTime().ToString(`"yyyyMMdd_HHmmss`") + `"_`" + ([Guid]::NewGuid().ToString(`"N`"))")
$null = $stLines.Add("  $Work=Join-Path $WorkRoot (`"tree_dualtx_`" + $Tag + `"_`" + $RunId)")
$null = $stLines.Add("  New-Item -ItemType Directory -Force -Path $Work | Out-Null")
$null = $stLines.Add("  $InputDir=Join-Path $Work `"input_tree`"")
$null = $stLines.Add("  $SnapDir =Join-Path $Work `"snapshot_tree_v1`"")
$null = $stLines.Add("  New-Item -ItemType Directory -Force -Path $InputDir | Out-Null")
$null = $stLines.Add("  New-Item -ItemType Directory -Force -Path (Join-Path $InputDir `"a`") | Out-Null")
$null = $stLines.Add("  New-Item -ItemType Directory -Force -Path (Join-Path $InputDir `"empty_dir`") | Out-Null")
$null = $stLines.Add("  $f=Join-Path $InputDir `"a\one.bin`"")
$null = $stLines.Add("  $size=262144")
$null = $stLines.Add("  $buf=New-Object byte[] $size")
$null = $stLines.Add("  for($i=0;$i -lt $size;$i++){ $buf[$i]=[byte](($i*19+7)%256) }")
$null = $stLines.Add("  [IO.File]::WriteAllBytes($f,$buf)")
$null = $stLines.Add("  [pscustomobject]@{ work=$Work; input=$InputDir; snap=$SnapDir }")
$null = $stLines.Add("}")
$null = $stLines.Add("")
$null = $stLines.Add("$r1 = New-RunDir `"A`"")
$null = $stLines.Add("$sid1 = & $Capture -RepoRoot $RepoRoot -InputDir $r1.input -OutDir $r1.snap -BlockSize 65536")
$null = $stLines.Add("$m1Path = Join-Path $r1.snap `"snapshot.tree.manifest.json`"")
$null = $stLines.Add("if(-not (Test-Path -LiteralPath $m1Path -PathType Leaf)){ Die (`"MISSING_MANIFEST_A: `"+$m1Path) }")
$null = $stLines.Add("$m1 = ReadJson $m1Path")
$null = $stLines.Add("")
$null = $stLines.Add("$r2 = New-RunDir `"B`"")
$null = $stLines.Add("$sid2 = & $Capture -RepoRoot $RepoRoot -InputDir $r2.input -OutDir $r2.snap -BlockSize 65536")
$null = $stLines.Add("$m2Path = Join-Path $r2.snap `"snapshot.tree.manifest.json`"")
$null = $stLines.Add("if(-not (Test-Path -LiteralPath $m2Path -PathType Leaf)){ Die (`"MISSING_MANIFEST_B: `"+$m2Path) }")
$null = $stLines.Add("$m2 = ReadJson $m2Path")
$null = $stLines.Add("")
$null = $stLines.Add("if([string]$m1.schema -ne `"triad.snapshot_tree.v1`"){ Die (`"MANIFEST_A_SCHEMA_BAD: `"+[string]$m1.schema) }")
$null = $stLines.Add("if([string]$m2.schema -ne `"triad.snapshot_tree.v1`"){ Die (`"MANIFEST_B_SCHEMA_BAD: `"+[string]$m2.schema) }")
$null = $stLines.Add("")
$null = $stLines.Add("# Roots must exist")
$null = $stLines.Add("$e1 = [string]$m1.roots.engine_transcript_root")
$null = $stLines.Add("$w1 = [string]$m1.roots.witness_transcript_root")
$null = $stLines.Add("$e2 = [string]$m2.roots.engine_transcript_root")
$null = $stLines.Add("$w2 = [string]$m2.roots.witness_transcript_root")
$null = $stLines.Add("if([string]::IsNullOrWhiteSpace($e1) -or $e1 -notmatch `"^[0-9a-f]{64}$`"){ Die `"ENGINE_ROOT_A_MISSING_OR_BAD`" }")
$null = $stLines.Add("if([string]::IsNullOrWhiteSpace($w1) -or $w1 -notmatch `"^[0-9a-f]{64}$`"){ Die `"WITNESS_ROOT_A_MISSING_OR_BAD`" }")
$null = $stLines.Add("if([string]::IsNullOrWhiteSpace($e2) -or $e2 -notmatch `"^[0-9a-f]{64}$`"){ Die `"ENGINE_ROOT_B_MISSING_OR_BAD`" }")
$null = $stLines.Add("if([string]::IsNullOrWhiteSpace($w2) -or $w2 -notmatch `"^[0-9a-f]{64}$`"){ Die `"WITNESS_ROOT_B_MISSING_OR_BAD`" }")
$null = $stLines.Add("")
$null = $stLines.Add("# Engine root MUST be stable across identical captures")
$null = $stLines.Add("if($e1 -ne $e2){ Die (`"ENGINE_ROOT_NOT_STABLE: A=`"+$e1+`" B=`"+$e2) }")
$null = $stLines.Add("")
$null = $stLines.Add("# Witness root SHOULD differ (ts_utc in hash basis)")
$null = $stLines.Add("if($w1 -eq $w2){ Die (`"WITNESS_ROOT_UNEXPECTEDLY_EQUAL: `"+$w1) }")
$null = $stLines.Add("")
$null = $stLines.Add("# Legacy alias must match witness root")
$null = $stLines.Add("if([string]$m1.roots.transcript_root -ne $w1){ Die `"LEGACY_TRANSCRIPT_ROOT_A_MISMATCH`" }")
$null = $stLines.Add("if([string]$m2.roots.transcript_root -ne $w2){ Die `"LEGACY_TRANSCRIPT_ROOT_B_MISMATCH`" }")
$null = $stLines.Add("")
$null = $stLines.Add("# Validate transcripts + root files")
$null = $stLines.Add("$w1Path = Join-Path $r1.snap ([string]$m1.witness_transcript.path -replace `"/`",`"\`")")
$null = $stLines.Add("$w1Root= Join-Path $r1.snap ([string]$m1.witness_transcript.root_path -replace `"/`",`"\`")")
$null = $stLines.Add("$e1Path = Join-Path $r1.snap ([string]$m1.engine_transcript.path -replace `"/`",`"\`")")
$null = $stLines.Add("$e1Root= Join-Path $r1.snap ([string]$m1.engine_transcript.root_path -replace `"/`",`"\`")")
$null = $stLines.Add("Validate-WitnessTranscript $w1Path $w1Root $w1")
$null = $stLines.Add("Validate-EngineTranscript  $e1Path $e1Root $e1")
$null = $stLines.Add("")
$null = $stLines.Add("# Legacy witness binding must exist and match witness")
$null = $stLines.Add("$legacyTx1  = Join-Path $r1.snap ([string]$m1.transcript.path -replace `"/`",`"\`")")
$null = $stLines.Add("$legacyRt1  = Join-Path $r1.snap ([string]$m1.transcript.root_path -replace `"/`",`"\`")")
$null = $stLines.Add("Validate-WitnessTranscript $legacyTx1 $legacyRt1 $w1")
$null = $stLines.Add("")
$null = $stLines.Add("$w2Path = Join-Path $r2.snap ([string]$m2.witness_transcript.path -replace `"/`",`"\`")")
$null = $stLines.Add("$w2Root= Join-Path $r2.snap ([string]$m2.witness_transcript.root_path -replace `"/`",`"\`")")
$null = $stLines.Add("$e2Path = Join-Path $r2.snap ([string]$m2.engine_transcript.path -replace `"/`",`"\`")")
$null = $stLines.Add("$e2Root= Join-Path $r2.snap ([string]$m2.engine_transcript.root_path -replace `"/`",`"\`")")
$null = $stLines.Add("Validate-WitnessTranscript $w2Path $w2Root $w2")
$null = $stLines.Add("Validate-EngineTranscript  $e2Path $e2Root $e2")
$null = $stLines.Add("")
$null = $stLines.Add("Write-Host `"`"")
$null = $stLines.Add("Write-Host `"========================================`" -ForegroundColor Green")
$null = $stLines.Add("Write-Host `"TRIAD TREE DUAL TRANSCRIPT SELFTEST: PASS`" -ForegroundColor Green")
$null = $stLines.Add("Write-Host (`"engine_transcript_root:  {0}`" -f $e1) -ForegroundColor Cyan")
$null = $stLines.Add("Write-Host (`"witness_root_A:          {0}`" -f $w1) -ForegroundColor DarkGray")
$null = $stLines.Add("Write-Host (`"witness_root_B:          {0}`" -f $w2) -ForegroundColor DarkGray")
$null = $stLines.Add("Write-Host (`"work_A: {0}`" -f $r1.work) -ForegroundColor DarkGray")
$null = $stLines.Add("Write-Host (`"work_B: {0}`" -f $r2.work) -ForegroundColor DarkGray")
$null = $stLines.Add("Write-Host `"========================================`" -ForegroundColor Green")
$null = $stLines.Add("Write-Host `"`"")
$st = (($stLines.ToArray()) -join "`n") + "`n"
Write-Utf8NoBomLf $SelfTestTx $st
Parse-Gate $SelfTestTx

$docLines = New-Object System.Collections.Generic.List[string]
$null = $docLines.Add("# TRIAD Tree Transcript Spec v1 (Dual)")
$null = $docLines.Add("")
$null = $docLines.Add("This document locks the **dual transcript** behavior for TRIAD tree snapshots:")
$null = $docLines.Add("")
$null = $docLines.Add("- **ENGINE transcript**: deterministic across identical inputs (no wall-clock time in hash basis).")
$null = $docLines.Add("- **WITNESS transcript**: run-unique (includes ``ts_utc`` in hash basis) to preserve timing evidence.")
$null = $docLines.Add("")
$null = $docLines.Add("The legacy binding remains:")
$null = $docLines.Add("- ``transcript.ndjson`` + ``snapshot.transcript_root`` still exist and are the **WITNESS** transcript.")
$null = $docLines.Add("")
$null = $docLines.Add("## Files in SnapshotDir (additional)")
$null = $docLines.Add("- ``engine.transcript.ndjson`` (UTF-8 no BOM, LF)")
$null = $docLines.Add("- ``snapshot.engine_transcript_root`` (UTF-8 no BOM, LF) - single 64-hex digest")
$null = $docLines.Add("- ``witness.transcript.ndjson`` (UTF-8 no BOM, LF)")
$null = $docLines.Add("- ``snapshot.witness_transcript_root`` (UTF-8 no BOM, LF) - single 64-hex digest")
$null = $docLines.Add("- Legacy alias (WITNESS): ``transcript.ndjson`` + ``snapshot.transcript_root``")
$null = $docLines.Add("")
$null = $docLines.Add("## Witness transcript line schema (v1)")
$null = $docLines.Add("Stable field order:")
$null = $docLines.Add("")
$null = $docLines.Add("``{ seq, ts_utc, event, prev_sha256, data_json, sha256 }``")
$null = $docLines.Add("")
$null = $docLines.Add("Line hash (witness):")
$null = $docLines.Add("``sha256 = SHA256( UTF8(`"triad.transcript_line.v1|<seq>|<ts_utc>|<event>|<prev_sha256>|<data_json>`") )``")
$null = $docLines.Add("")
$null = $docLines.Add("## Engine transcript line schema (v1)")
$null = $docLines.Add("Stable field order:")
$null = $docLines.Add("")
$null = $docLines.Add("``{ seq, event, prev_sha256, data_json, sha256 }``")
$null = $docLines.Add("")
$null = $docLines.Add("Line hash (engine):")
$null = $docLines.Add("``sha256 = SHA256( UTF8(`"triad.engine_transcript_line.v1|<seq>|<event>|<prev_sha256>|<data_json>`") )``")
$null = $docLines.Add("")
$null = $docLines.Add("## transcript_root (Merkle)")
$null = $docLines.Add("For both engine + witness:")
$null = $docLines.Add("- leaves are 32-byte digests (line.sha256 in transcript order)")
$null = $docLines.Add("- pairwise SHA-256 over concatenated digests")
$null = $docLines.Add("- duplicate last digest if odd count")
$null = $docLines.Add("")
$null = $docLines.Add("## Manifest binding (v1)")
$null = $docLines.Add("Tree manifest roots include:")
$null = $docLines.Add("")
$null = $docLines.Add("- ``roots.engine_transcript_root = <engine_root>``")
$null = $docLines.Add("- ``roots.witness_transcript_root = <witness_root>``")
$null = $docLines.Add("- ``roots.transcript_root = <witness_root>`` (legacy alias)")
$null = $docLines.Add("")
$null = $docLines.Add("And paths:")
$null = $docLines.Add("- ``engine_transcript.path = `"engine.transcript.ndjson`"``")
$null = $docLines.Add("- ``engine_transcript.root_path = `"snapshot.engine_transcript_root`"``")
$null = $docLines.Add("- ``witness_transcript.path = `"witness.transcript.ndjson`"``")
$null = $docLines.Add("- ``witness_transcript.root_path = `"snapshot.witness_transcript_root`"``")
$null = $docLines.Add("- ``transcript.path = `"transcript.ndjson`"`` (legacy witness)")
$null = $docLines.Add("- ``transcript.root_path = `"snapshot.transcript_root`"`` (legacy witness)")
$null = $docLines.Add("")
$null = $docLines.Add("## Canonical selftest")
$null = $docLines.Add("- ``scripts\_selftest_triad_tree_transcript_v1.ps1`` runs two identical captures and asserts:")
$null = $docLines.Add("  - engine transcript root is identical across runs")
$null = $docLines.Add("  - witness transcript root differs across runs")
$null = $docLines.Add("  - both transcripts validate (chain + per-line hash + Merkle root)")
$doc = (($docLines.ToArray()) -join "`n") + "`n"
Write-Utf8NoBomLf $DocPath $doc

Write-Host "PATCH_APPLIED+PARSE_OK:" -ForegroundColor Green
Write-Host ("  {0}" -f $CaptureTree) -ForegroundColor Cyan
Write-Host ("  {0}" -f $SelfTestTx)  -ForegroundColor Cyan
Write-Host ("  {0}" -f $DocPath)     -ForegroundColor DarkGray
Write-Host ("backup_dir: {0}" -f $BackupDir) -ForegroundColor DarkGray

