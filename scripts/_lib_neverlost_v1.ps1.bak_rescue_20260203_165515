  if(-not (Test-Path -LiteralPath $FilePath)){ Die ("FILE_MISSING: " + $FilePath) }

  $ssh = Get-OpenSshKeygen
  $dir = Split-Path -Parent ([IO.Path]::GetFullPath($FilePath))
